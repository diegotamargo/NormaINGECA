# =====================================================================
# NormaINGECA v2 - SHARED configuration
# =====================================================================
# Used everywhere: by 'python -m app.ingest' (run manually from any PC)
# and by worker PCs (via the installer). All machines point to the same
# shared folder for PDFs and vector indexes — there is no separate
# "ingest server" with its own local folders. The only machine-specific
# setting is GOOGLE_API_KEY (which only workers use for generation; the
# ingest run never calls an LLM).
# =====================================================================

# --- Shared document & index paths (same URLs for ingest and all workers) ---
# Edit these to match your company's shared folder structure.
# The ingest run reads PDFs from PDF_DIR_* and writes indexes to
# VECTOR_DIR_*. Workers load both from the same shared paths.
PDF_DIR_NORMATIVA=
VECTOR_DIR_NORMATIVA=
PDF_DIR_EDPR=
VECTOR_DIR_EDPR=
PDF_DIR_TECNOLOGO=
VECTOR_DIR_TECNOLOGO=

# --- Embedding model (both ingest and workers run it locally) ---
# MUST be the same everywhere: Qwen3-Embedding-0.6B, the model that
# built the indexes and that queries must be embedded with.
EMBED_BACKEND=local
LOCAL_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B

# --- Chunking (must stay consistent between ingest runs) ---
CHUNK_SIZE=1024
CHUNK_OVERLAP=100

# --- Retrieval ---
SIMILARITY_TOP_K=4
NUM_QUERIES=1
# The reranker (bge-reranker-v2-m3) is the precision pass over the small
# embedder's candidates. It downloads on first run (~1.1 GB). Set to false
# on a machine too memory-constrained to load it.
USE_RERANKER=true

# --- Generation LLM (Gemini via Google AI Studio; worker-only) ---
# The ingest run never calls this; only workers generating answers use it.
LLM_BACKEND=api
API_PROVIDER=google
API_LLM_MODEL=gemini-3.1-flash-lite
# IMPORTANT: Each worker installation needs its own API key from
# https://aistudio.google.com/apikey to avoid saturating the shared quota.
# NEVER commit this value to version control.
GOOGLE_API_KEY=

# --- Queue & concurrency (worker-only) ---
MAX_CONCURRENT_LLM=2
MAX_QUEUE_SIZE=50
QUEUE_TIMEOUT=120
GENERATION_TIMEOUT=300

# --- Web serving (worker-only) ---
APP_HOST=127.0.0.1
APP_PORT=58734
FRONTEND_DIST_DIR=frontend
OPEN_BROWSER=true
